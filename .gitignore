# ======================================================
# Automatically generated files by NixOS
# ======================================================

# Hardware configuration auto-generated (nixos-generate-config --dir /etc/nixos)
hardware-configuration.nix

# Generated by nixos-generate-config
/boot/*

# ======================================================
# Temporary files and caches
# ======================================================
*.swp
*.swo
*.bak
*~
*.tmp
*.log

# ======================================================
# Build directories and Nix store
# ======================================================
/result
/nix/store/
/nix/var/nix/profiles/
/nix/var/nix/gcroots/
/nix/var/nix/profiles/
/nix/var/nix/temproot/
*.lock
!flake.lock

# ======================================================
# Personal configuration and secrets
# ======================================================
*.secret
*.key
*.pem

# ======================================================
# Editors / IDEs
# ======================================================
.idea/
/.vscode/
/*.code-workspace
*.sublime-project
*.sublime-workspace